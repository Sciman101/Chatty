; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

_global_script_classes=[{
"base": "SyntaxHighlighter",
"class": &"ChattySyntaxHighlighter",
"language": &"GDScript",
"path": "res://scripts/chatty/chatty_syntax_highlighter.gd"
}, {
"base": "RichTextEffect",
"class": &"RichTextAppear",
"language": &"GDScript",
"path": "res://scripts/text_effects/text_effect_appear.gd"
}, {
"base": "RichTextEffect",
"class": &"RichTextGlitch",
"language": &"GDScript",
"path": "res://scripts/text_effects/text_effect_glitch.gd"
}, {
"base": "SpriteFrames",
"class": &"Speaker",
"language": &"GDScript",
"path": "res://scripts/chatty/speaker.gd"
}]
_global_script_class_icons={
"ChattySyntaxHighlighter": "",
"RichTextAppear": "",
"RichTextGlitch": "",
"Speaker": ""
}

[application]

config/name="Chatty"
run/main_scene="res://scene/demo.tscn"
config/features=PackedStringArray("4.0")
config/icon="res://graphics/icon.svg"

[autoload]

Chatty="*res://scripts/chatty/chatty.gd"
SpeakerLoader="*res://scripts/chatty/speaker_loader.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"

[editor]

movie_writer/movie_file="C:/Users/Scima/Videos/Godot Movie Mode/movie.avi"

[rendering]

2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true
